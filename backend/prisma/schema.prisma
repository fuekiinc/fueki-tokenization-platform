generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  walletAddress String?  @unique
  role          String   @default("user") // "user" | "admin" | "super_admin"
  kycStatus     String   @default("not_submitted") // not_submitted, pending, approved, rejected
  helpLevel     String   @default("novice") // novice | intermediate | expert
  demoUsed      Boolean  @default(false)
  demoActive    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  kycData              KYCData?
  sessions             Session[]
  passwordResetTokens  PasswordResetToken[]
  mintApprovalRequests MintApprovalRequest[]
  securityTokenApprovalRequests SecurityTokenApprovalRequest[]
  deployedContracts   DeployedContract[]

  @@index([email])
  @@index([walletAddress])
}

model KYCData {
  id                  String   @id @default(uuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // All PII fields are AES-256-GCM encrypted
  encryptedFirstName  String
  encryptedLastName   String
  encryptedDOB        String
  encryptedSSN        String
  encryptedAddress1   String
  encryptedAddress2   String?
  encryptedCity       String
  encryptedState      String
  encryptedZipCode    String
  encryptedCountry    String

  documentType        String   // drivers_license or passport
  documentPath        String   // encrypted file stored on disk
  documentOrigName    String
  subscriptionPlan    String?  // monthly, annual, full_service, or contract_deployment_* variants

  submittedAt         DateTime @default(now())
  reviewedAt          DateTime?
  reviewNotes         String?

  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @unique
  rememberMe   Boolean  @default(false)
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([refreshToken])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model AdminActionToken {
  id        String   @id @default(uuid())
  userId    String   // the KYC applicant
  action    String   // "approve" or "reject"
  token     String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
}

model MintApprovalRequest {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  requesterEmail   String
  chainId          Int
  tokenName        String
  tokenSymbol      String
  mintAmount       String
  recipient        String
  documentHash     String
  documentType     String
  originalValue    String
  currency         String
  fileName         String
  fileMimeType     String
  requestFingerprint String
  status           String   @default("pending") // pending, approved, rejected
  reviewNotes      String?
  reviewedAt       DateTime?
  approvedBy       String?
  submittedAt      DateTime @default(now())
  updatedAt        DateTime @updatedAt

  actionTokens     MintApprovalActionToken[]

  @@index([userId, requestFingerprint])
  @@index([status])
  @@index([documentHash])
}

model MintApprovalActionToken {
  id         String   @id @default(uuid())
  requestId  String
  request    MintApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  action     String   // approve, reject
  token      String   @unique
  used       Boolean  @default(false)
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([token])
  @@index([requestId])
}

model SecurityTokenApprovalRequest {
  id                 String   @id @default(uuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  requesterEmail     String
  chainId            Int
  tokenName          String
  tokenSymbol        String
  decimals           Int
  totalSupply        String
  maxTotalSupply     String
  minTimelockAmount  String
  maxReleaseDelayDays Int
  originalValue      String
  documentHash       String
  documentType       String
  hashSource         String   // file, manual
  fileName           String?
  fileMimeType       String?
  requestFingerprint String
  status             String   @default("pending") // pending, approved, rejected
  reviewNotes        String?
  reviewedAt         DateTime?
  approvedBy         String?
  submittedAt        DateTime @default(now())
  updatedAt          DateTime @updatedAt

  actionTokens       SecurityTokenApprovalActionToken[]

  @@index([userId, requestFingerprint])
  @@index([status])
  @@index([documentHash])
}

model SecurityTokenApprovalActionToken {
  id         String   @id @default(uuid())
  requestId  String
  request    SecurityTokenApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  action     String   // approve, reject
  token      String   @unique
  used       Boolean  @default(false)
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([token])
  @@index([requestId])
}

model DeployedContract {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId       String
  templateName     String
  contractAddress  String
  deployerAddress  String
  chainId          Int
  txHash           String
  constructorArgs  Json     @default("{}")
  abi              Json     @default("[]")
  blockNumber      Int?
  gasUsed          String?
  deployedAt       DateTime @default(now())
  createdAt        DateTime @default(now())

  @@unique([chainId, contractAddress])
  @@index([userId])
  @@index([chainId])
}
