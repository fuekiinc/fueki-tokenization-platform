generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  walletAddress String?  @unique
  role          String   @default("user") // "user" | "admin" | "super_admin"
  accessRevokedAt DateTime?
  accessRevokedBy String?
  accessRevocationReason String?
  kycStatus     String   @default("not_submitted") // not_submitted, pending, approved, rejected
  helpLevel     String   @default("novice") // novice | intermediate | expert
  demoUsed      Boolean  @default(false)
  demoActive    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  kycData              KYCData?
  sessions             Session[]
  passwordResetTokens  PasswordResetToken[]
  walletConnections    UserWalletConnection[]
  mintApprovalRequests MintApprovalRequest[]
  securityTokenApprovalRequests SecurityTokenApprovalRequest[]
  deployedContracts   DeployedContract[]

  @@index([email])
  @@index([walletAddress])
}

model UserWalletConnection {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletAddress    String   @db.VarChar(42)
  firstConnectedAt DateTime @default(now())
  lastConnectedAt  DateTime @default(now())
  connectionCount  Int      @default(1)

  @@unique([userId, walletAddress])
  @@index([userId])
  @@index([walletAddress])
  @@index([userId, lastConnectedAt])
}

model KYCData {
  id                  String   @id @default(uuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // All PII fields are AES-256-GCM encrypted
  encryptedFirstName  String
  encryptedLastName   String
  encryptedDOB        String
  encryptedSSN        String
  encryptedAddress1   String
  encryptedAddress2   String?
  encryptedCity       String
  encryptedState      String
  encryptedZipCode    String
  encryptedCountry    String

  documentType        String   // drivers_license or passport
  documentPath        String   // encrypted file stored on disk
  documentOrigName    String
  documentMimeType    String?
  documentBackPath    String?
  documentBackOrigName String?
  documentBackMimeType String?
  liveVideoPath       String?
  liveVideoOrigName   String?
  liveVideoMimeType   String?
  subscriptionPlan    String?  // monthly, annual, full_service, or contract_deployment_* variants

  submittedAt         DateTime @default(now())
  reviewedAt          DateTime?
  reviewNotes         String?

  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @unique // SHA-256 hex digest of the refresh token
  rememberMe   Boolean  @default(false)
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([refreshToken])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique // SHA-256 hex digest of the reset token
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model AdminActionToken {
  id        String   @id @default(uuid())
  userId    String   // the KYC applicant
  action    String   // "approve" or "reject"
  token     String   @unique // SHA-256 hex digest of the action token
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
}

model MintApprovalRequest {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  requesterEmail   String
  requesterWalletAddress String?
  chainId          Int
  tokenName        String
  tokenSymbol      String
  mintAmount       String
  recipient        String
  documentHash     String
  documentType     String
  originalValue    String
  currency         String
  fileName         String
  fileMimeType     String
  requestFingerprint String
  status           String   @default("pending") // pending, approved, rejected
  reviewNotes      String?
  reviewedAt       DateTime?
  approvedBy       String?
  submittedAt      DateTime @default(now())
  updatedAt        DateTime @updatedAt

  actionTokens     MintApprovalActionToken[]

  @@index([userId, requestFingerprint])
  @@index([userId, requesterWalletAddress, requestFingerprint])
  @@index([status])
  @@index([documentHash])
  @@index([requesterWalletAddress])
}

model MintApprovalActionToken {
  id         String   @id @default(uuid())
  requestId  String
  request    MintApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  action     String   // approve, reject
  token      String   @unique // SHA-256 hex digest of the action token
  used       Boolean  @default(false)
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([token])
  @@index([requestId])
}

model SecurityTokenApprovalRequest {
  id                 String   @id @default(uuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  requesterEmail     String
  requesterWalletAddress String?
  chainId            Int
  tokenName          String
  tokenSymbol        String
  decimals           Int
  totalSupply        String
  maxTotalSupply     String
  minTimelockAmount  String
  maxReleaseDelayDays Int
  originalValue      String
  documentHash       String
  documentType       String
  hashSource         String   // file, manual
  fileName           String?
  fileMimeType       String?
  requestFingerprint String
  status             String   @default("pending") // pending, approved, rejected
  reviewNotes        String?
  reviewedAt         DateTime?
  approvedBy         String?
  submittedAt        DateTime @default(now())
  updatedAt          DateTime @updatedAt

  actionTokens       SecurityTokenApprovalActionToken[]

  @@index([userId, requestFingerprint])
  @@index([userId, requesterWalletAddress, requestFingerprint])
  @@index([status])
  @@index([documentHash])
  @@index([requesterWalletAddress])
}

model SecurityTokenApprovalActionToken {
  id         String   @id @default(uuid())
  requestId  String
  request    SecurityTokenApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  action     String   // approve, reject
  token      String   @unique // SHA-256 hex digest of the action token
  used       Boolean  @default(false)
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([token])
  @@index([requestId])
}

enum ContractTemplateType {
  ERC20
  ERC721
  ERC1155
  ERC1404
  STAKING
  AUCTION
  ESCROW
  SPLITTER
  LOTTERY
  CUSTOM
}

model DeployedContract {
  id                  String               @id @default(uuid())
  userId              String
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId          String
  templateName        String
  contractName        String
  templateType        ContractTemplateType @default(CUSTOM)
  contractAddress     String
  deployerAddress     String
  walletAddress       String
  chainId             Int
  txHash              String               @unique
  constructorArgs     Json?
  abi                 Json                 @default("[]")
  sourceCode          String?
  compilationWarnings String[]             @default([])
  blockNumber         BigInt?
  gasUsed             String?
  deployedAt          DateTime             @default(now())
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@unique([chainId, contractAddress])
  @@index([userId])
  @@index([chainId])
  @@index([walletAddress])
  @@index([walletAddress, chainId])
}

model NavOracleRegistration {
  id                            String   @id @default(uuid())
  tokenAddress                  String   @db.VarChar(42)
  chainId                       Int
  oracleAddress                 String   @db.VarChar(42)
  baseCurrency                  String   @default("USD") @db.VarChar(10)
  stalenessWarningDays          Int      @default(90)
  stalenessCriticalDays         Int      @default(180)
  minAttestationIntervalSeconds Int      @default(86400)
  maxNavChangeBps               Int      @default(5000)
  lastIndexedBlock              BigInt?
  createdBy                     String
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  attestations        NavAttestation[]
  publisherAssignments NavPublisherAssignment[]

  @@unique([tokenAddress, chainId])
  @@unique([oracleAddress, chainId])
  @@index([chainId])
}

model NavAttestation {
  id               String               @id @default(uuid())
  tokenAddress     String               @db.VarChar(42)
  chainId          Int
  oracleAddress    String               @db.VarChar(42)
  navPerToken      Decimal              @db.Decimal(36, 6)
  totalNAV         Decimal              @db.Decimal(36, 6)
  totalTokenSupply Decimal              @db.Decimal(36, 0)
  baseCurrency     String               @default("USD") @db.VarChar(10)
  effectiveDate    DateTime
  publishedAt      DateTime?
  createdAt        DateTime             @default(now())
  publisherAddress String               @db.VarChar(42)
  publisherName    String?
  reportHash       String               @db.VarChar(66)
  reportURI        String
  txHash           String?              @db.VarChar(66)
  attestationIndex Int?
  indexedBlockNumber BigInt?
  status           NavAttestationStatus @default(PUBLISHED)

  oracleRegistration NavOracleRegistration @relation(fields: [tokenAddress, chainId], references: [tokenAddress, chainId], onDelete: Cascade)
  assetSnapshots      NavAssetSnapshot[]

  @@unique([tokenAddress, chainId, attestationIndex])
  @@index([tokenAddress, chainId, effectiveDate(sort: Desc)])
  @@index([publisherAddress])
  @@index([txHash])
}

model NavAssetSnapshot {
  id                  String   @id @default(uuid())
  attestationId       String
  assetName           String
  assetType           String
  grossAssetValue     Decimal  @db.Decimal(36, 6)
  liabilities         Decimal  @db.Decimal(36, 6) @default(0)
  netAssetValue       Decimal  @db.Decimal(36, 6)
  provenReservesOz    Decimal? @db.Decimal(36, 6)
  probableReservesOz  Decimal? @db.Decimal(36, 6)
  spotPricePerOz      Decimal? @db.Decimal(36, 6)
  productionRateTpd   Decimal? @db.Decimal(36, 6)
  notes               String?  @db.Text
  createdAt           DateTime @default(now())

  attestation NavAttestation @relation(fields: [attestationId], references: [id], onDelete: Cascade)

  @@index([attestationId])
}

model NavPublisher {
  id            String   @id @default(uuid())
  walletAddress String   @unique @db.VarChar(42)
  name          String
  licenseNumber String?
  licenseType   String?
  contactEmail  String?
  isActive      Boolean  @default(true)
  addedBy       String
  addedAt       DateTime @default(now())
  updatedAt     DateTime @updatedAt

  assignments NavPublisherAssignment[]

  @@index([isActive])
}

model NavPublisherAssignment {
  id            String   @id @default(uuid())
  tokenAddress   String   @db.VarChar(42)
  chainId        Int
  walletAddress  String   @db.VarChar(42)
  isActive       Boolean  @default(true)
  addedBy        String
  addedAt        DateTime @default(now())
  updatedAt      DateTime @updatedAt
  revokedAt      DateTime?
  revokedBy      String?

  oracleRegistration NavOracleRegistration @relation(fields: [tokenAddress, chainId], references: [tokenAddress, chainId], onDelete: Cascade)
  publisher          NavPublisher          @relation(fields: [walletAddress], references: [walletAddress], onDelete: Cascade)

  @@unique([tokenAddress, chainId, walletAddress])
  @@index([walletAddress])
  @@index([tokenAddress, chainId, isActive])
}

enum NavAttestationStatus {
  DRAFT
  PENDING_TX
  PUBLISHED
  SUPERSEDED
  DISPUTED
}
