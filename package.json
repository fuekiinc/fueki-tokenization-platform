{
  "name": "tokenization-platform",
  "private": true,
  "version": "0.7.1",
  "type": "module",
  "scripts": {
    "dev": "node scripts/run-supported-node.mjs 22.12.0 node_modules/vite/bin/vite.js",
    "build": "tsc -b && node scripts/run-supported-node.mjs 22.12.0 node_modules/vite/bin/vite.js build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test:unit:legacy": "tsx --test tests/unit/*.test.ts",
    "test:unit": "vitest run --project unit --config vitest.config.ts",
    "test:unit:coverage": "vitest run --project unit --coverage --config vitest.config.ts",
    "test:vitest": "vitest run --config vitest.config.ts",
    "test:vitest:ui": "vitest --ui --config vitest.config.ts",
    "test:vitest:coverage": "vitest run --coverage --config vitest.config.ts",
    "test:vitest:coverage:strict": "VITEST_ENFORCE_COVERAGE=true vitest run --coverage --config vitest.config.ts",
    "test:vitest:typecheck": "vitest typecheck --config vitest.config.ts",
    "test:api": "vitest run --project api --config vitest.config.ts",
    "test:api:load": "node tests/performance/run-load-tests.mjs",
    "test:db": "node tests/utils/check-test-db.mjs && vitest run --project api --config vitest.config.ts tests/api/database.integration.test.ts",
    "test:contracts:hardhat": "hardhat test tests/contracts/hardhat/*.test.js",
    "test:contracts:forge": "forge test --root . --match-path 'tests/contracts/forge/*.t.sol' -vv",
    "test:contracts:forge:fuzz": "forge test --root . --match-path 'tests/contracts/forge/*.t.sol' --match-test testFuzz -vv",
    "test:contracts": "npm run contracts:build && npm run test:contracts:hardhat",
    "test:security": "bash tests/security/run-security-audit.sh",
    "test:performance": "node tests/performance/run-load-tests.mjs",
    "test:lighthouse": "lhci autorun --config tests/performance/lighthouserc.json",
    "test:reports": "node tests/reports/generate-report-index.mjs",
    "test:all:new": "bash tests/run-all-tests.sh",
    "test:smoke:new": "bash tests/quick-smoke-test.sh",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e tests/help-guidance.spec.ts --project=chromium",
    "test:e2e:a11y": "playwright test tests/accessibility.spec.ts --project=chromium",
    "test:all": "npm run test:unit && npm run test:e2e:smoke",
    "preview": "node scripts/run-supported-node.mjs 22.12.0 node_modules/vite/bin/vite.js preview",
    "frontend:update": "./scripts/deploy-frontend-cloudrun.sh",
    "backend:migrate": "cd backend && npx prisma migrate deploy",
    "backend:update": "cd backend && npm run build && cd .. && gcloud run deploy fueki-backend --source backend --region us-central1 --port 8080 --env-vars-file backend/cloudrun.env.yaml --add-cloudsql-instances extreme-lodge-463919-d9:us-central1:fueki-db",
    "contracts:build": "npx hardhat compile && npx tsx scripts/extract-template-artifacts.ts",
    "proxy:connect": "cloud-sql-proxy extreme-lodge-463919-d9:us-central1:fueki-db --port 5459",
    "symphony:setup": "bash scripts/symphony/setup.sh",
    "symphony:doctor": "bash scripts/symphony/doctor.sh",
    "symphony:run": "bash scripts/symphony/run.sh"
  },
  "dependencies": {
    "@datadog/browser-logs": "^6.27.1",
