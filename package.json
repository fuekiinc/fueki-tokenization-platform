{
  "name": "tokenization-platform",
  "private": true,
  "version": "0.4.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test:unit": "tsx --test tests/unit/*.test.ts",
    "test:unit:coverage": "c8 --reporter=text --reporter=lcov --reporter=json-summary --all --include=src/lib/**/*.ts --include=src/components/Forms/signupSchemas.ts tsx --test tests/unit/*.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e tests/help-guidance.spec.ts --project=chromium",
    "test:e2e:a11y": "playwright test tests/accessibility.spec.ts --project=chromium",
    "test:all": "npm run test:unit && npm run test:e2e:smoke",
    "preview": "vite preview",
    "frontend:update": "tsc -b && vite build && gcloud run deploy fueki-frontend --source . --region us-central1 --set-build-env-vars VITE_API_URL=${VITE_API_URL:-https://fueki-backend-pojr5zp2oq-uc.a.run.app}",
    "backend:migrate": "cd backend && npx prisma migrate deploy",
    "backend:update": "cd backend && npm run build && cd .. && gcloud run deploy fueki-backend --source backend --region us-central1 --port 8080 --env-vars-file backend/cloudrun.env.yaml --add-cloudsql-instances extreme-lodge-463919-d9:us-central1:fueki-db",
    "contracts:build": "npx hardhat compile && npx tsx scripts/extract-template-artifacts.ts",
    "proxy:connect": "cloud-sql-proxy extreme-lodge-463919-d9:us-central1:fueki-db --port 5457"
  },
  "dependencies": {
    "@datadog/browser-logs": "^6.27.1",
    "@datadog/browser-rum": "^6.27.1",
    "@googlemaps/js-api-loader": "^2.0.2",
    "@headlessui/react": "^2.2.9",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-virtual": "^3.13.18",
    "axios": "^1.13.5",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "ethers": "^6.16.0",
    "fast-xml-parser": "^5.3.5",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^0.563.0",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "^5.4.624",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-dropzone": "^14.4.0",
    "react-hook-form": "^7.71.1",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^6.30.3",
    "recharts": "^3.7.0",
    "tesseract.js": "^7.0.0",
    "thirdweb": "^5.118.2",
    "use-places-autocomplete": "^4.0.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^9.39.1",
    "@nomicfoundation/hardhat-toolbox": "^6.1.0",
    "@openzeppelin/contracts": "^4.9.6",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.18",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^24.10.1",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "c8": "^10.1.3",
    "dotenv": "^17.2.4",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "hardhat": "^2.28.4",
    "solc": "^0.8.28",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
