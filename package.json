    "pdfjs-dist": "^5.4.624",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-dropzone": "^14.4.0",
    "react-hook-form": "^7.71.1",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^6.30.3",
    "recharts": "^3.7.0",
    "tesseract.js": "^7.0.0",
    "thirdweb": "^5.119.1",
    "use-places-autocomplete": "^4.0.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
